FROM node:22.22.2-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

# Rewrites in next.config.ts read process.env at build time — all vars required
ARG INVENTORY_SERVICE_URL
ARG ORDER_SERVICE_URL
ARG PICKING_SERVICE_URL
ARG SHIPPING_SERVICE_URL
ARG INBOUND_SIMULATOR_URL
ARG DISPATCH_SIMULATOR_URL
ARG ORDER_SIMULATOR_URL
ARG PICKING_SIMULATOR_URL

ENV INVENTORY_SERVICE_URL=$INVENTORY_SERVICE_URL
ENV ORDER_SERVICE_URL=$ORDER_SERVICE_URL
ENV PICKING_SERVICE_URL=$PICKING_SERVICE_URL
ENV SHIPPING_SERVICE_URL=$SHIPPING_SERVICE_URL
ENV INBOUND_SIMULATOR_URL=$INBOUND_SIMULATOR_URL
ENV DISPATCH_SIMULATOR_URL=$DISPATCH_SIMULATOR_URL
ENV ORDER_SIMULATOR_URL=$ORDER_SIMULATOR_URL
ENV PICKING_SIMULATOR_URL=$PICKING_SIMULATOR_URL

RUN npm run build

CMD ["npm", "start"]
