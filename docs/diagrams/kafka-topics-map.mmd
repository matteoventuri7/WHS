graph LR
    subgraph Producers["Produttori"]
        ORD_P[Order Service]
        INV_P[Inventory Service]
        PICK_P[Picking Service]
        SHIP_P[Shipping Service]
    end

    subgraph Topics["Kafka Topics"]
        OP[OrderPlaced]
        OC[OrderCancelled]
        ORP[OrderReadyForPicking]
        OS[OrderSuspended]
        IA[InventoryAllocated]
        OOS[OutOfStock]
        IS[ItemStored]
        PTC[PickingTaskCreated]
        PTCO[PickingTaskCompleted]
        CPT[CancelPickingTask]
        SA[ShipmentAssigned]
        VD[VehicleDispatched]
        VR[VehicleRegistered]
    end

    subgraph Consumers["Consumatori"]
        ORD_C[Order Service]
        INV_C[Inventory Service]
        PICK_C[Picking Service]
        SHIP_C[Shipping Service]
    end

    %% Producers → Topics
    ORD_P --> OP
    ORD_P --> OC
    ORD_P --> ORP
    ORD_P --> OS
    ORD_P --> CPT
    INV_P --> IA
    INV_P --> OOS
    INV_P --> IS
    PICK_P --> PTC
    PICK_P --> PTCO
    SHIP_P --> SA
    SHIP_P --> VD
    SHIP_P --> VR

    %% Topics → Consumers
    OP --> INV_C
    OC --> INV_C
    IA --> ORD_C
    OOS --> ORD_C
    IS --> ORD_C
    PTCO --> ORD_C
    SA --> ORD_C
    ORP --> PICK_C
    CPT --> PICK_C
    PTCO --> SHIP_C
